{
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "no-explicit-any": "off",
    "no-console": "warn",
    "no-extraneous-class": "off",
    "no-unnecessary-type-arguments": "off",
    "throw-new-error": "off",
    "consistent-function-scoping": "off",
    "preserve-caught-error": "off"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
