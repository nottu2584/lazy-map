{
  "name": "@lazy-map/api-contracts",
  "version": "1.0.0",
  "description": "Auto-generated API types and client from OpenAPI spec",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "echo 'No build needed - TypeScript types only'",
    "generate": "openapi-typescript ../../apps/backend/openapi.json -o src/generated/types.ts && prettier --write src/generated/types.ts",
    "clean": "rm -rf node_modules"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "prettier": "^3.8.3"
  }
}
