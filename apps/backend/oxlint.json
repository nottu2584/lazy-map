{
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "no-empty-interface": "off",
    "no-explicit-any": "off",
    "no-console": "off",
    "no-extraneous-class": "off",
    "no-unnecessary-type-arguments": "off"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "**/*.test.ts"
  ]
}
