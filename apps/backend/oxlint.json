{
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "typescript/no-empty-interface": "off",
    "typescript/no-explicit-any": "off",
    "typescript/no-extraneous-class": "off",
    "eslint/no-console": "off"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "**/*.test.ts"
  ]
}
